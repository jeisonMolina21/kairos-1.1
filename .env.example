# Ejemplo de configuración de API
API_EMAIL=tu_email@ejemplo.com
API_PASSWORD=tu_password
API_PRIMARY_URL=http://localhost:5000/api
API_SECONDARY_URL=https://api.ejemplo.com/api
API_TIMEOUT=15

# Configuración de rutas
OUTPUT_DIR=outputs
TEMP_DIR=temp
REPORTS_DIR=reports
LOGS_DIR=logs

# Configuración de logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
